Process Hospital is
    Task Medico is
	Entry atenderEnfermera;
	Entry atenderPaciente;
    End Medico;

    Task Type Enfermera;
    Task Bloc is
	Entry guardar(nota: in text);
	Entry sacar(nota: out text);
    End Bloc;

    Task Type Persona;

    Personas: Array (0..P-1) of Persona;
    Enfermera: Array (0..E-1) of Enfermera;

    Task Type Body Persona is
	contEnojo: integer:= 0;
    Begin
	While (contEnojo < 3) Loop
	    Select
		Medico.atenderPaciente;
	    OR Delay 300.0
		Delay 600.0
		contEnojo:= contEnojo + 1;
	    End Select;
	End Loop;
    End Persona;

    Task Type Body Enfermera is
	peticion: text;
    Begin
	Loop
	    // Trabaja y genera peticion
	    Select
		Medico.atenderEnfermera;
	    OR Else
		// Escribir peticion
		Bloc.guardar(peticion);
	End Loop;
    End Enfermera;

    Task Body Bloc is
	cola: Queue;
    Begin
	Loop
	    Select
		Accept guardar(peticion);
		cola.add(peticion);
		End guardar;
	    OR
		When (!cola.isEmpty()) => Accept sacar(peticion);
		peticion:= cola.pop();
		End sacar;
	End Loop;
    End Bloc;

    Task Body Medico is
	notaAct: text;
    Begin
	Loop
	    While ((atenderEnfermera'Count + atenderPaciente'count) != 0) LoopW
		Select
		    Accept atenderPaciente;
		    // Procesar Pedido
		    End atenderPaciente;
		OR
		    When (atenderPaciente'Count = 0) => Accept atenderEnfermera;
		    // Procesar pedido
		    End atenderEnfermera;
		End Select;
	    End LoopW; //Este loop es necesario porque no se pueden hacer calls y accepts en un mismo select
	    Select
		Bloc.sacar(notaAct);
		// Procesar nota;
	    OR Else
		null;
	    End Select;
	End Loop;
    End Medico;
Begin
    null;
End Hospital;

