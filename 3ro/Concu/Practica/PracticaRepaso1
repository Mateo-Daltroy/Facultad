sem mutexArr = 1;
int posAct = 0;
int cantCodigo[10] = 0;
sem codigo[10] = 1;

Process Worker [1..7] {
    int miNum;
    int ret;
    P(mutexArr);
    while (posAct < 10.000) {
	miNum = posAct;
	posAct++;
	V(mutexArr);
	ret = Validar(miNum);
	P(codigo[ret]);
	cantCodigo[ret]++;
	V(codigo[ret]);
    }
    -- cont ++ ; sumar al vector
    if (miNum == 9.999 // cont = 7) {
	for (int i = 0; i < 10; i++) {
	    Print(cantCodigo[i]);
	}
    }
}

