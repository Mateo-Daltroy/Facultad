Procedure Puente is
    Task type Auto;

    Task type Camioneta;

    Task type Camion;

    Task type Gestor is
	Entry pedirPasoAuto;
	Entry pedirPasoCamioneta;
	Entry pedirPasoCamion;
	Entry liberarPeso (peso: in int);
    End Gestor;

    Autos: array (0..infinito) of Auto;
    Camionetas: array (0..infinito) of Camioneta;
    Camiones: array (0..infinito) of Camion;

    Task body Auto is
    Begin
	Gestor.pedirPasoAuto
	// Paso
	Gestor.liberarPeso(1);
    End Auto;

    Task body Camioneta is
    Begin
	Gestor.pedirPasoCamioneta
	// Paso
	Gestor.liberarPeso(2);
    End Camioneta;

    Task body Camion is
    Begin
	Gestor.pedirPasoCamion
	// Paso
	Gestor.liberarPeso(3);
    End Camion;

    Task body Gestor is
	pesoAct: integer = 5;
	aux: integer;
    Begin
	Loop
	    Select
		When (pesoAct >= 1) => Accept pedirPasoAuto;
		    pesoAct:= pesoAct - 1;
		End pedirPasoAuto;
	    OR
		When (pesoAct >= 2) => Accept pedirPasoCamioneta;
		    pesoAct:= pesoAct - 2;
		End pedirPasoCamioneta;
	    OR
		When (pesoAct >= 3) => Accept pedirPasoCamion;
		    pesoAct:= pesoAct - 3;
		End pedirPasoCamion;
	    OR
		accept liberarPeso(aux);
		    pesoAct:= pesoAct + aux;
		End liberarPeso;
	    End Select;
	End Loop;
    End Gestor;
End Puente;


