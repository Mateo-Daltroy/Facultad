Monitor Equipo[1..5] {
    int control = 0;
    int total = 0;
    cond espera;

    Procedure llegar() {
	if (control != 3) {
	    control++;
	    wait(espera);
	}
	else {
	    signal_all(espera);
	    control = 0;
	}
    }

    Procedure cerrar(cont: in int; tot: out int) {
	total+= cont;
	if (control != 3) {
	    control++;
	    wait(espera);
	}
	else {
	    signal_all(espera);
	    control = 0;
	}
	tot = total;
    }
}

