    Monitor Motor
    {
	cond cola;
	int contCola = 0;
	int lectoresLibres = 5;

	Procedure solicitarAtencion()
	{
	    if (lectoresLibres == 0)
	    {
		contCola++;
		wait(cola);
	    }
	    else 
	    {
		lectoresLibres--;
	    }
	}

	Procedure finalizarAtencion()
	{
	    if (contCola != 0)
	    {
		signal(cola);
		contCola--;
	    }
	    else
	    {
		lectoresLibres++;
	    }
	}
    }

