Monitor Cancha {
    int cont = 0;
    cond espera;
    cond listos;

    Process llegar()
    {
	cont++;
	if (cont == 22)
	{
	    signal(listos);
	}
	wait(espera);
    }

    Process iniciar()
    {
	if (cont < 22) -> wait(listos);
    }

    Process finalizar()
    {
	signal_all(espera);
    }
}


