    cola eLibres;
    int empleadosLibres = 0;

    Procedure proximo(idE: in int)
    {
	push(eLibres, idE);
	if (contador > 0)
	{
	    contador--;
	    signal(cola);
	}
	else
	{
	    empleadosLibres++;
	}
    }

    Procedure llegada(idE: out int)
    {
	if (empleadosLibres == 0)
	{
	    contador++;
	    wait(cola)
	}
	else
