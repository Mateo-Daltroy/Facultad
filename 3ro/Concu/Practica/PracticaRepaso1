# Monitores

1)
Process Persona [id: 0..N-1] {
    int edad = generarEdad(id);
    bool embarazada = generarEmbarazo(id);
    MaquinaVoto.solicitarAcceso(id, edad, embarazada);
    Votar();
    MaquinaVoto.finalizarAcceso();
}

Process AutoridadMesa {
    for (int i = 0; i < N; i++)
    {
	MaquinaVoto.siguientePersona();
	MaquinaVoto.esperarFinal();
    }
}

Monitor MaquinaVoto {
    cola q;
    cond llegada;
    cond mutex;
    cond miTurno[N];
    int contCola = 0;
    bool libre = true;

    Procedure solicitarAcceso(id: int; edad: int; emb: bool)
    {
	if (contCola == 0) -> signal(llegada);
	contCola++;
	push(q, id, edad, emb);
	wait(miTurno[id]);
    }

    Procedure siguientePersona()
    {
	int sigId;
	if (contCola == 0) -> wait(llegada);
	pop(q, sigId);
	signal(miTurno[sigId]);
	contCola--;
    }

    Procedure finalizarAcceso()
    {
	signal(mutex);
    }

    Procedure esperarFinal()
    {
	wait(mutex);
    }
}

