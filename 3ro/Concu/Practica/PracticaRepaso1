Process Escalador [id: 1..30] {
    -- llega
    Paso.pedirAcceso(id);
    -- pasar
    Paso.lierarAcceso();
}

Monitor Paso {
    cola q;
    cond mutex[30];
    bool libre = true;

    Procedure pedirAcceso (id: in int) {
	if (!libre) {
	    push(q, id);
	    wait(mutex[id]);
	} else {
	    libre = false;
	}
    }

    Procedure librerarAceso() {
	int sigId;
	if (q.isEmpty()) -> libre = true;
	else {
	    pop(q, sigId);
	    signal(mutex[sigId]);
	}
    }
}
