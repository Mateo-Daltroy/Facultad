Process Sistema is
    Task Proceso1;
    Task Proceso2;

    Task Timer is
	Entry init;
    End Timer;

    Task Central is
	Entry recibirP1(sen: in text);
	Entry recibirP2(sen: in text);
	Entry finTimer;
    End Central;

    Task Body Proceso1 is
	sen: text;
    Begin
	Loop
	    sen:= //Generar senal
	    Select
		Central.recibirP1(sen);
	    OR Delay 120.0
	End Loop;
    End Proceso1;

    Task Body Proceso2 is
	sen: text;
	senAck: boolean:= true;
    Begin
	Loop
	    if (senAck) then
		senAck:= false;
		sen:= //Generar senal
	    end if;
	    Select
		Central.recibirP2(sen);
		senAck:= true;
	    OR Delay 60.0
		Null
	    End Select;
	End Loop;
    End Proceso2;

    Task Body Timer is
    Begin
	Accept init;
	Delay 180.0;
	Central.finTimer;
    End Timer;

    Task Body Central is
	sen: text;
	timer: boolean;
    Begin
	 Accept recibirP1(sen);
	 Loop
	    // Procesar senal
	    Select
		Accept recibirP1(sen);
	    OR
		Accept recibirP2(sen);
		Timer.init
		timer:= true;
		while (timer) do
		    Select
			Accept recibirP2(sen);
		    OR
			Accept finTimer;
			timer:= false;
		    End Select;
		End while;
	 End Loop;
    End Central;
End Sistema;


