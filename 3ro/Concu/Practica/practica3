    Process Auto \[id: 0..N-1]
    {
      int miPeso; //Inicializado cada uno con su peso propio
      Puente.solicitarPaso(miPeso);
      -- pasa el puente
      Puente.pasarPuente(miPeso);
    }

    Monitor Puente
    {
	int pesoRes = 50.000;
	cond cola;
	cola q;
	int nextPeso = -1;
	int esperando = 0;
	
	Procedure solicitarPaso(peso: in int)
	{
	    if ((pesoRes - peso) < 0 || esperando > 0)
	    {
		esperando++;
		if (nextPeso == -1) -> nextPeso = peso;
		else -> push(q, peso);
		wait(cola);
		esperando--;
	    }
	    pesoRes = pesoRes - peso;
	    if (esperando > 0)
	    {
		pop(q, nextPeso);
		if (pesoRes > nextPeso) -> signal(cola);
	    }
	    else -> nextPeso = -1;
	}

	Procedure pasarPuente(peso: in int)
	{
	    pesoRes = pesoRes + peso;
	    if (pesoRes >= nextPeso)
	    {
		signal(cola);
	    }
	}
    }

